{
  "compilerOptions": {
    "target": "esnext",
    "moduleResolution": "node",
    "baseUrl": "./",
    "jsx": "react",
    "declaration": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "paths": {
      "@/*": ["src/*"],
      "@@/*": [".dumi/tmp/*"],
      "@rc-component/menu": ["src/index.ts"]
    }
  },
  "include": ["src", "docs", ".dumirc.ts"],
  "exclude": ["node_modules", "lib", "es", "dist", "docs-dist", ".dumi"]
}
